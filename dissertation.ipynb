   "source": [
    "import pandas as pd\n",
    "\n",
    "def load_ushant_ais(path, bbox=None, max_speed=40):\n",
    "    \"\"\"Semikolonlu AIS CSV okur ve speed, heading, dt döndürür.\n",
    "    QC: hız kapa, tekrarlı timestamp sil, opsiyonel bbox.\n",
    "    bbox=(lon_min, lon_max, lat_min, lat_max)\n",
    "    \"\"\"\n",
    "    df = pd.read_csv(path, sep=';')\n",
    "    df.columns = [c.strip().lower() for c in df.columns]\n",
    "    time_col = next((c for c in ['timestamp','t','time'] if c in df.columns), None)\n",
    "    if time_col is None:\n",
    "        raise ValueError('timestamp column missing')\n",
    "    df[time_col] = pd.to_datetime(df[time_col])\n",
    "    df = df.sort_values(time_col).drop_duplicates(subset=time_col)\n",
    "    if 'speed' not in df.columns:\n",
    "        for c in ['sog','speed_over_ground','velocity']:\n",
    "            if c in df.columns:\n",
    "                df['speed'] = df[c]\n",
    "                break\n",
    "    if 'heading' not in df.columns:\n",
    "        for c in ['heading','cog','course']:\n",
    "            if c in df.columns:\n",
    "                df['heading'] = df[c]\n",
    "                break\n",
    "    df['speed'] = df['speed'].clip(upper=max_speed)\n",
    "    df['dt'] = df[time_col].diff().dt.total_seconds().clip(lower=1e-6).fillna(1e-6)\n",
    "    if bbox is not None:\n",
    "        lon_col = next((c for c in ['lon','longitude'] if c in df.columns), None)\n",
    "        lat_col = next((c for c in ['lat','latitude'] if c in df.columns), None)\n",
    "        if lon_col and lat_col:\n",
    "            lon_min, lon_max, lat_min, lat_max = bbox\n",
    "            df = df[df[lon_col].between(lon_min, lon_max) & df[lat_col].between(lat_min, lat_max)]\n",
    "    return df[['speed','heading','dt']]\n"
   ]
}